{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",

    "target": "ES2023",
    "lib": ["ES2023"],

    "module": "ESNext",
    "moduleResolution": "bundler",

    "types": ["node"],

    "skipLibCheck": true,
    "incremental": true,

    "noEmit": true,

    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },

  "include": ["vite.config.ts"],
  "exclude": ["dist", "node_modules"]
}
