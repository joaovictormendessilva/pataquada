{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",

    "target": "ES2023",
    "lib": ["ES2023", "DOM"],

    "module": "ESNext",
    "moduleResolution": "bundler",

    "baseUrl": ".",
    "paths": {
      "src/*": ["src/*"]
    },

    "jsx": "react-jsx",

    "types": ["vite/client"],

    "skipLibCheck": true,
    "incremental": true,

    "noEmit": true,

    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },

  "include": ["src"],
  "exclude": ["dist", "node_modules"]
}
